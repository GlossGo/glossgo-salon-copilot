# Either GOOGLE_API_KEY (AI Studio) OR Vertex AI creds via gcloud auth ADC
GOOGLE_API_KEY=AIzaSy...                  # pull from `doppler secrets get GEMINI_API_KEY ...`
GOOGLE_GENAI_USE_VERTEXAI=0               # set to 1 to use Vertex AI; needs GOOGLE_CLOUD_PROJECT + LOCATION

# Models
ORCHESTRATOR_MODEL=gemini-2.5-pro
SUBAGENT_MODEL=gemini-2.5-flash

# MCP transport: stdio (local dev) or sse (Cloud Run)
MCP_TRANSPORT=stdio
COPILOT_REPO_ROOT=/abs/path/to/glossgo-salon-copilot

# When MCP_TRANSPORT=sse, set these to the Cloud Run service URLs
MCP_DATA_URL=https://mcp-data-xxx.a.run.app/sse
MCP_COMMS_URL=https://mcp-comms-xxx.a.run.app/sse
MCP_CALENDAR_URL=https://mcp-calendar-xxx.a.run.app/sse
MCP_BEARER_TOKEN=                          # shared secret for SSE auth (Secret Manager in prod)

# Safety
SHADOW_MODE=true                           # never send real WhatsApp; draft-only
